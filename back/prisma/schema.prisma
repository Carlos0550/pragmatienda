generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  FREE
  STARTER
  PRO
}


enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  DELETED
  BLOCKED
}

enum ProductsStatus {
  PUBLISHED
  UNPUBLISHED
  DELETED
  ARCHIVED
  LOW_STOCK
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  PROCESSED
  CANCELLED
  REFUNDED
  SHIPPED
  DELIVERED
  COMPLETED
  FAILED
  REFUND_REQUESTED
  REFUND_APPROVED
  REFUND_REJECTED
  REFUND_COMPLETED
  REFUND_FAILED
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELED
  EXPIRED
}

enum FulfillmentStatus {
  UNFULFILLED
  PREPARING
  SHIPPED
  DELIVERED
  RETURNED
  CANCELED
}

enum ShippingMethodKind {
  THIRD_PARTY
  EXTERNAL
  PICKUP
}

enum ShippingProviderCode {
  CUSTOM_EXTERNAL
  LOCAL_PICKUP
  SHIPNOW
}

enum ShippingQuoteType {
  HOME_DELIVERY
  PICKUP
}

enum OrderShipmentStatus {
  DRAFT
  QUOTED
  PENDING_CREATION
  READY_FOR_PICKUP
  PREPARING
  SHIPPED
  DELIVERED
  CANCELED
  FAILED
}

enum PaymentProvider {
  MERCADOPAGO_INTEGRATION
  BANK_TRANSFER
  CASH
  DEBIT_CARD
  CREDIT_CARD
  OTHER
}

enum BillingStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model Tenant {
  id           String     @id @default(cuid())
  ownerId      String
  owner        User       @relation("TenantOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  plan         PlanType   @default(FREE)
  planStartsAt DateTime   @default(now())
  planEndsAt   DateTime?
  trialEndsAt  DateTime?
  billingStatus BillingStatus @default(INACTIVE)
  currentSubscriptionId String? @unique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  users              User[]            @relation("TenantUsers")
  productsCategories ProductsCategory[] @relation("TenantProductsCategory")
  businessData       BusinessData?     @relation("TenantBusiness")
  products           Products[]        @relation("TenantProducts")
  cart               Cart[]            @relation("TenantCart")
  guestCarts         GuestCart[]       @relation("TenantGuestCart")
  order              Order[]           @relation("TenantOrder")
  paymentEvents      PaymentEvent[]    @relation("TenantPaymentEvents")
  idempotencyKeys    IdempotencyKey[]  @relation("TenantIdempotencyKeys")
  paymentAccounts    StorePaymentAccount[] @relation("TenantPaymentAccounts")
  payments           Payment[]         @relation("TenantPayments")
  subscriptions      Subscription[]    @relation("TenantSubscriptions")
  currentSubscription Subscription?    @relation("TenantCurrentSubscription", fields: [currentSubscriptionId], references: [id])
  sales Sales[] @relation("TenantSales")
  shippingMethods ShippingMethod[] @relation("TenantShippingMethods")
  shipmentQuotes ShipmentQuote[] @relation("TenantShipmentQuotes")
  shipnowConfig ShipnowConfig? @relation("TenantShipnowConfig")
}


model BusinessData {
  id        String   @id @default(cuid())
  name      String
  description String?
  address String?
  province String?
  businessHours String?
  country String @default("Argentina")
  phone String?
  email String?
  website String   @unique
  logo String?
  favicon String?
  banner String?
  banners Json?
  bannerOverlayPosition String?
  seoImage String?
  seoDescription String?
  socialMedia Json?
  bankOptions Json?
  tenantId  String   @unique
  tenant    Tenant   @relation("TenantBusiness", fields: [tenantId], references: [id], onDelete: Cascade)

  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  @@index([name])
  @@unique([phone])
  @@unique([email])
}


model User {
  id        String   @id @default(cuid())
  email     String   
  phone     String?   
  name      String?
  password  String
  role      Int      @default(1)
  avatar    String?
  isVerified Boolean  @default(false)
  status     UserStatus @default(ACTIVE)
  tenantId  String?
  tenant    Tenant? @relation("TenantUsers", fields: [tenantId], references: [id], onDelete: Cascade)
  ownedTenants Tenant[] @relation("TenantOwner")
  cart Cart[] @relation("UserCart")
  order Order[] @relation("UserOrder")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([email, tenantId, role])
}



model ProductsCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String?
  description String?
  metaTitle String?
  metaDescription String?
  image String?
  tenantId String
  tenant Tenant @relation("TenantProductsCategory", fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Products[] @relation("ProductsCategory")

  @@index([name])
  @@index([slug])
  @@unique([tenantId, name])
  @@unique([tenantId, slug])
}

model Products {
  id        String   @id @default(cuid())
  name      String
  description String?
  barCode String?
  image String?
  metadata Json?
  slug String?
  metaTitle String?
  metaDescription String?
  price Decimal
  stock Int
  weightGrams Int?
  lengthCm Decimal?
  widthCm Decimal?
  heightCm Decimal?
  status ProductsStatus @default(PUBLISHED)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  tenantId String
  categoryId String?
  orderItem OrderItem[] @relation("ProductOrderItems")
  tenant Tenant @relation("TenantProducts", fields: [tenantId], references: [id], onDelete: Cascade)
  category ProductsCategory? @relation("ProductsCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  cart CartItem[] @relation("ProductCartItems") //pendiente hacer migracion de indices
  guestCartItems GuestCartItem[] @relation("ProductGuestCartItems")
  @@index([name])
  @@index([slug])
  @@index([barCode])
  @@index([status])
  @@index([barCode, tenantId])
  @@index([status, tenantId])
  @@unique([tenantId, slug])
}

model Cart{
  id String @id @default(cuid())
  tenantId String
  userId String
  items CartItem[] @relation("CartItems")
  user User @relation("UserCart", fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation("TenantCart", fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@unique([tenantId, userId])
}

model CartItem{
  id String @id @default(cuid())
  cartId String
  cart Cart @relation("CartItems", fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product Products @relation("ProductCartItems", fields: [productId], references: [id], onDelete: Cascade)
  quantity Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([productId])
  @@unique([cartId, productId])
}

model GuestCart {
  id String @id @default(cuid())
  tenantId String
  token String
  items GuestCartItem[] @relation("GuestCartItems")
  tenant Tenant @relation("TenantGuestCart", fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@unique([token])
  @@unique([tenantId, token])
}

model GuestCartItem {
  id String @id @default(cuid())
  guestCartId String
  guestCart GuestCart @relation("GuestCartItems", fields: [guestCartId], references: [id], onDelete: Cascade)
  productId String
  product Products @relation("ProductGuestCartItems", fields: [productId], references: [id], onDelete: Cascade)
  quantity Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guestCartId])
  @@index([productId])
  @@unique([guestCartId, productId])
}

model Order{
  id String @id @default(cuid())
  tenantId String
  userId String?
  guestName String?
  guestEmail String?
  guestPhone String?
  
  status OrderStatus @default(PENDING)
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED)
  tax Decimal @default(0)
  
  billingAddress Json?
  customerNote String?
  items OrderItem[] @relation("OrderItems")
  sales Sales[] @relation("OrderSales")
  shipment OrderShipment?
  user User? @relation("UserOrder", fields: [userId], references: [id], onDelete: SetNull)
  tenant Tenant @relation("TenantOrder", fields: [tenantId], references: [id], onDelete: Cascade)
  paymentEvents PaymentEvent[] @relation("OrderPaymentEvents")
  payments Payment[] @relation("OrderPayments")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([fulfillmentStatus])
}

model OrderItem{
  id String @id @default(cuid())
  orderId String?
  order Order? @relation("OrderItems", fields: [orderId], references: [id], onDelete: SetNull)
  productId String
  product Products @relation("ProductOrderItems", fields: [productId], references: [id], onDelete: Cascade)
  sales Sales[] @relation("OrderItemSales")
  quantity Int
  unitPrice Decimal @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@unique([orderId, productId])
}

model PaymentEvent {
  id String @id @default(cuid())
  tenantId String
  orderId String?
  provider String
  eventId String
  eventType String
  payload Json
  processedAt DateTime @default(now())
  createdAt DateTime @default(now())

  tenant Tenant @relation("TenantPaymentEvents", fields: [tenantId], references: [id], onDelete: Cascade)
  order Order? @relation("OrderPaymentEvents", fields: [orderId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([orderId])
  @@index([provider])
  @@index([eventType])
  @@unique([provider, eventId])
}

model IdempotencyKey {
  id String @id @default(cuid())
  tenantId String
  scope String
  key String
  requestHash String
  responseStatus Int?
  responseBody Json?
  createdAt DateTime @default(now())
  expiresAt DateTime

  tenant Tenant @relation("TenantIdempotencyKeys", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
  @@unique([tenantId, scope, key])
}

model StorePaymentAccount {
  id String @id @default(cuid())
  storeId String @map("store_id")
  provider PaymentProvider
  mpUserId String? @map("mp_user_id")
  accessToken String @map("access_token")
  refreshToken String? @map("refresh_token")
  publicKey String? @map("public_key")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store Tenant @relation("TenantPaymentAccounts", fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([provider])
  @@index([mpUserId])
  @@unique([storeId, provider])
  @@map("store_payment_accounts")
}

model Payment {
  id String @id @default(cuid())
  storeId String @map("store_id")
  orderId String @map("order_id")
  provider PaymentProvider
  externalPaymentId String @map("external_payment_id")
  status String
  statusDetail String? @map("status_detail")
  amount Decimal
  currency String
  rawResponse Json @map("raw_response")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store Tenant @relation("TenantPayments", fields: [storeId], references: [id], onDelete: Cascade)
  order Order @relation("OrderPayments", fields: [orderId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([externalPaymentId])
  @@unique([provider, externalPaymentId])
  @@map("payments")
}

model Plan {
  id            String   @id @default(cuid())
  code          PlanType @unique
  name          String
  description   String?
  price         Decimal
  currency      String   @default("ARS")
  interval      String   @default("month")
  trialDays     Int      @default(0)
  mpPreapprovalPlanId String?
  active        Boolean  @default(true)
  maxProducts   Int?     // null = sin límite
  maxCategories Int?     // null = sin límite
  features      Json?    // ej: { "reports": true, "api": false }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[] @relation("PlanSubscriptions")
}

model Subscription {
  id String @id @default(cuid())

  tenantId String
  tenant Tenant @relation("TenantSubscriptions", fields: [tenantId], references: [id], onDelete: Cascade)

  planId String
  plan Plan @relation("PlanSubscriptions", fields: [planId], references: [id])

  externalSubscriptionId String @unique

  status BillingStatus

  currentPeriodStart DateTime?
  currentPeriodEnd DateTime?

  cancelAtPeriodEnd Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events SubscriptionEvent[] @relation("SubscriptionEvents")
  currentTenants Tenant[] @relation("TenantCurrentSubscription")

  @@index([tenantId])
  @@index([status])
}

model SubscriptionEvent {
  id String @id @default(cuid())

  subscriptionId String
  subscription Subscription @relation("SubscriptionEvents", fields: [subscriptionId], references: [id], onDelete: Cascade)

  type String
  payload Json

  createdAt DateTime @default(now())

  @@index([subscriptionId])
}


model Sales{
  id String @id @default(cuid())

  total Decimal @default(0)
  saleDate DateTime @default(now())
  status PaymentStatus @default(PENDING)
  paymentProofImage String?
  discount Decimal @default(0)
  currency String @default("ARS")
  paymentProvider PaymentProvider
  
  orderId String?
  orderItemId String?
  tenantId String
  
  order Order? @relation("OrderSales", fields: [orderId], references: [id], onDelete: SetNull)
  tenant Tenant @relation("TenantSales", fields: [tenantId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation("OrderItemSales", fields: [orderItemId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model ShippingMethod {
  id String @id @default(cuid())
  tenantId String
  name String
  kind ShippingMethodKind
  providerCode ShippingProviderCode
  isActive Boolean @default(true)
  availableInCheckout Boolean @default(true)
  availableInAdmin Boolean @default(true)
  displayOrder Int @default(0)
  config Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation("TenantShippingMethods", fields: [tenantId], references: [id], onDelete: Cascade)
  zoneRules ShippingZoneRule[] @relation("ShippingMethodZoneRules")
  quotes ShipmentQuote[] @relation("ShippingMethodQuotes")
  shipments OrderShipment[] @relation("ShippingMethodShipments")

  @@index([tenantId])
  @@index([providerCode])
  @@index([isActive])
}

model ShippingZoneRule {
  id String @id @default(cuid())
  shippingMethodId String
  province String
  locality String?
  price Decimal
  isActive Boolean @default(true)
  displayName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shippingMethod ShippingMethod @relation("ShippingMethodZoneRules", fields: [shippingMethodId], references: [id], onDelete: Cascade)

  @@index([shippingMethodId])
  @@index([province, locality])
}

model ShipmentQuote {
  id String @id @default(cuid())
  tenantId String
  shippingMethodId String
  providerCode ShippingProviderCode
  quoteType ShippingQuoteType
  serviceCode String?
  serviceName String?
  price Decimal
  currency String @default("ARS")
  destination Json?
  packageSummary Json?
  providerPayload Json?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation("TenantShipmentQuotes", fields: [tenantId], references: [id], onDelete: Cascade)
  shippingMethod ShippingMethod @relation("ShippingMethodQuotes", fields: [shippingMethodId], references: [id], onDelete: Cascade)
  shipment OrderShipment?

  @@index([tenantId])
  @@index([shippingMethodId])
  @@index([providerCode])
}

model OrderShipment {
  id String @id @default(cuid())
  orderId String @unique
  shippingMethodId String
  quoteId String? @unique
  providerCode ShippingProviderCode
  kind ShippingMethodKind
  status OrderShipmentStatus @default(DRAFT)
  price Decimal @default(0)
  currency String @default("ARS")
  serviceCode String?
  serviceName String?
  trackingCode String?
  labelUrl String?
  externalShipmentId String?
  destination Json?
  originSnapshot Json?
  pickupSnapshot Json?
  providerQuotePayload Json?
  providerShipmentPayload Json?
  pickedUpAt DateTime?
  shippedAt DateTime?
  deliveredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shippingMethod ShippingMethod @relation("ShippingMethodShipments", fields: [shippingMethodId], references: [id], onDelete: Restrict)
  quote ShipmentQuote? @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([shippingMethodId])
  @@index([providerCode])
  @@index([status])
  @@index([trackingCode])
}

model ShipnowConfig {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  tenant    Tenant   @relation("TenantShipnowConfig", fields: [tenantId], references: [id], onDelete: Cascade)
  acceptedTerms Boolean @default(false)
  acceptedAt DateTime?
  config Json? // Configuración adicional específica del tenant
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}
